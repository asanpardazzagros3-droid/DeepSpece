openssf.org            - نام: نصب جاوا JDK
  موارد استفاده: actions/setup-java@v5.4.0
  با:
    # نسخه جاوا برای تنظیم. یک نسخه کامل یا متوسط جاوا را در نظر میگیرد. نمونههایی از نحو پشتیبانی شده را در فایل README ببینید.
    نسخه جاوا: # اختیاری
    # مسیر فایلی که حاوی نسخه جاوا برای تنظیم است (.java-version، .tool-versions، .sdkmanrc). زمانی استفاده میشود که java-version تنظیم نشده باشد. نمونههایی از سینتکس پشتیبانی شده را در فایل README ببینید.
    فایل-نسخه-جاوا: # اختیاری
    # توزیع جاوا. لیست توزیعهای پشتیبانیشده را در فایل README مشاهده کنید.
    توزیع:
    # نوع بسته (jdk، jre، jdk+fx، jre+fx)
    java-package: # اختیاری، پیشفرض jdk است
    # معماری بسته (پیشفرض معماری action runner)
    معماری: # اختیاری
    # مسیر جایی که JDK فشرده شده قرار دارد
    jdkFile: # اختیاری
    # اگر میخواهید اکشن آخرین نسخه موجود که مشخصات نسخه را برآورده میکند، بررسی کند، این گزینه را تنظیم کنید
    بررسی آخرین: # اختیاری
    # شناسه مخزن distributionManagement در فایل pom.xml. پیشفرض `github` است.
    شناسه سرور: # اختیاری، پیشفرض github است
    # نام متغیر محیطی برای نام کاربری جهت احراز هویت در مخزن Apache Maven. مقدار پیشفرض $GITHUB_ACTOR است.
    نام کاربری سرور: # اختیاری، پیشفرض GITHUB_ACTOR است
    # نام متغیر محیطی برای رمز عبور یا توکن برای احراز هویت در مخزن Apache Maven. مقدار پیشفرض $GITHUB_TOKEN است.
    رمز عبور سرور: # اختیاری، پیشفرض GITHUB_TOKEN است
    # مسیر جایی که فایل settings.xml نوشته خواهد شد. مقدار پیشفرض ~/.m2 است.
    مسیر تنظیمات: # اختیاری
    # در صورت وجود فایل settings.xml، آن را بازنویسی کنید. مقدار پیشفرض "true" است.
    تنظیمات بازنویسی: # اختیاری، پیشفرض درست است
    # کلید خصوصی GPG برای وارد کردن. پیشفرض رشته خالی است.
    gpg-private-key: # اختیاری، پیشفرض
    # نام متغیر محیطی برای عبارت عبور کلید خصوصی GPG. وقتی gpg-private-key تنظیم شده باشد، پیشفرض GPG_PASSPHRASE است؛ در غیر این صورت نادیده گرفته میشود.
    عبارت عبور gpg: # اختیاری
    # نام پلتفرم ساخت برای ذخیره وابستگیها. میتواند "maven"، "gradle" یا "sbt" باشد.
    حافظه پنهان: # اختیاری
    # مسیر یک فایل وابستگی: pom.xml، build.gradle، build.sbt و غیره. این گزینه را میتوان با گزینه `cache` استفاده کرد. اگر این گزینه حذف شود، اکشن به دنبال فایل وابستگی در کل مخزن جستجو میکند. این گزینه از wildcardها و لیستی از نام فایلها برای ذخیره چندین وابستگی پشتیبانی میکند.
    مسیر وابستگی به حافظه پنهان: # اختیاری
    # راه حل برای ارسال وضعیت کار به مرحلهی بعد از کار. این متغیر برای تنظیم دستی در نظر گرفته نشده است.
    job-status: # اختیاری، پیشفرض ‎${{ job.status }}‎ است
    # توکنی که برای احراز هویت هنگام دریافت مانیفستهای نسخه میزبانی شده در github.com، مانند نسخه مایکروسافت OpenJDK، استفاده میشود. هنگام اجرای این اقدام در github.com، مقدار پیشفرض کافی است. هنگام اجرا روی GHES، اگر با محدودیت سرعت مواجه هستید، میتوانید یک توکن دسترسی شخصی برای github.com ارسال کنید.
    token: # اختیاری، مقدار پیشفرض ${{ github.server_url == 'https://github.com' && github.token || '' }} است
    # نام شناسهی زنجیرهی ابزار Maven در صورتی که نام پیشفرض "${distribution}_${java-version}" مورد نظر نباشد. نمونههایی از سینتکس پشتیبانیشده را در فایل Advanced Usage ببینید.
    mvn-toolchain-id: # اختیاری
    # نام فروشندهی زنجیرهی ابزار Maven در صورتی که نام پیشفرض "${distribution}" مورد نظر نباشد. نمونههایی از سینتکس پشتیبانیشده را در فایل Advanced Usage ببینید.
    mvn-toolchain-vendor: # اختیاری
          
